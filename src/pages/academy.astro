---
/**
 * /academy - Course listing page
 */
import { getEmDashCollection } from "emdash";
import Layout from "virtual:emdash-lms/layout";
import { basePath } from "virtual:emdash-lms/config";

const { entries: courses, cacheHint } = await getEmDashCollection("courses");
Astro.response.headers.set("Cache-Control", cacheHint ?? "public, max-age=60");

const publishedCourses = courses
  .filter((c) => c.data.status === "publish")
  .toSorted((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));
---

<Layout title="Academy" description="Browse all courses">
  <div class="lms-academy">
    <header class="lms-page-header">
      <h1>Academy</h1>
      <p>Explore our courses</p>
    </header>

    {publishedCourses.length === 0 ? (
      <p class="lms-empty">No courses available yet.</p>
    ) : (
      <div class="lms-courses-grid">
        {publishedCourses.map((course) => (
          <a
            href={`${basePath}/course/${course.data.slug || course.id}`}
            class="lms-course-card"
          >
            {course.data.featured_image && (
              <img
                src={course.data.featured_image}
                alt={course.data.title}
                loading="lazy"
              />
            )}
            <div class="lms-course-card-body">
              <h3>{course.data.title}</h3>
              {course.data.excerpt && <p>{course.data.excerpt}</p>}
              {course.data.difficulty && (
                <span class="lms-difficulty-badge">{course.data.difficulty}</span>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
